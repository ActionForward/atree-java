{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/main/.schema/devbox.schema.json",
  "packages": [
    "javaPackages.compiler.temurin-bin.jdk-25@latest",
    "gradle_9@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Devbox ready: '$(java -version 2>&1 | head -n 1)' / '$(gradle --version | grep Gradle)"
    ],
    "scripts": {
      "build": "gradle assemble testClasses",
      "test": "gradle test",
      "jmh": "gradle jmh",
      "clean": "gradle clean"
    }
  }
}
